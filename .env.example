# ============================================================
# NAUTICA STORE — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no Git!
# ============================================================

# ─── Servidor ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados PostgreSQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nautica_store
DB_USER=postgres
DB_PASSWORD=troque_esta_senha
DB_SSL=false   # true em produção (Railway, Supabase, etc.)

# ─── Autenticação JWT ────────────────────────────────────────────
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_

# ─── Admin inicial (usado no seed.js) ───────────────────────────
ADMIN_EMAIL=admin@nautica.com
ADMIN_SENHA_INICIAL=troque_esta_senha_apos_primeiro_login

# ─── WhatsApp ────────────────────────────────────────────────────
WHATSAPP_NUMERO=5592999999999   # com código do país e DDD

# ─── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ─── Uploads / Armazenamento ─────────────────────────────────────
# Opção 1: local (só para desenvolvimento)
UPLOAD_DESTINO=local

# Opção 2: Google Cloud Storage (produção)
# GCS_BUCKET=nome-do-seu-bucket
# GOOGLE_APPLICATION_CREDENTIALS=./gcs-key.json
